#!/usr/bin/make -f
# -*- mode: makefile; coding: utf-8 -*-

SY_ENABLED_MODULES := camera-arv,camera-lc,camera-tis,miniscope

ifneq (,$(filter $(DEB_HOST_ARCH), amd64))
    # We don't build Intan support on non-amd64, Intan does not support this officially
	SY_ENABLED_MODULES := $(SY_ENABLED_MODULES),intan-rhx,open-ephys-acq
endif

SY_CONFIGURE_ARGS = \
    -Doptimize-modern-amd64=true \
    -Dmodules=$(SY_ENABLED_MODULES)

%:
	dh $@

override_dh_auto_configure:
	cd $(CURDIR) && dh_auto_configure -- $(SY_CONFIGURE_ARGS)

override_dh_auto_install:
	dh_auto_install

	rm -rf $(CURDIR)/debian/tmp/usr/include/quill
	rm -f $(CURDIR)/debian/tmp/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig/quill.pc

override_dh_auto_test:
	:

override_dh_shlibdeps:
	# we make some modules runtime-optional, so the user can install support on-demand
	dh_shlibdeps -Xmodules/camera-tis/camera-tis.so -Xmodules/miniscope/miniscope.so

override_dh_strip:
	dh_strip --automatic-dbgsym
